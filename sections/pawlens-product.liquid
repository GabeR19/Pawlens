{{ 'pawlens.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- comment -%} Map the "default bundle" setting to a variant position (1-based). {%- endcomment -%}
{%- assign default_index = 2 -%}
{%- case section.settings.default_bundle -%}
  {%- when 'single' -%}{%- assign default_index = 1 -%}
  {%- when 'popular' -%}{%- assign default_index = 2 -%}
  {%- when 'pro' -%}{%- assign default_index = 3 -%}
{%- endcase -%}

<div class="pawlens-section">

<!-- ============== ANNOUNCEMENT BAR ============== -->
<div class="announcement" aria-label="Site announcements">
  <div class="announcement-track" aria-hidden="true">
    <span>FREE US SHIPPING</span><span aria-hidden="true">·</span>
    <span>30-DAY MONEY-BACK GUARANTEE</span><span aria-hidden="true">·</span>
    <span>1080P FISHEYE HD</span><span aria-hidden="true">·</span>
    <span>SEE THE WORLD FROM THEIR EYES</span><span aria-hidden="true">·</span>
    <span>FREE US SHIPPING</span><span aria-hidden="true">·</span>
    <span>30-DAY MONEY-BACK GUARANTEE</span><span aria-hidden="true">·</span>
    <span>1080P FISHEYE HD</span><span aria-hidden="true">·</span>
    <span>SEE THE WORLD FROM THEIR EYES</span><span aria-hidden="true">·</span>
  </div>
</div>

<!-- ============== NAV ============== -->
<header class="nav" id="nav">
  <div class="container nav-inner">
    <a class="brand" href="#top" aria-label="{{ shop.name | escape }} home">
      <svg class="brand-mark" viewBox="0 0 64 64" aria-hidden="true">
        <rect width="64" height="64" rx="14" fill="currentColor"/>
        <circle cx="32" cy="32" r="14" fill="#F5F0E8"/>
        <circle cx="32" cy="32" r="6" fill="currentColor"/>
      </svg>
      <span class="brand-word">pawlens</span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="#features">Features</a>
      <a href="#reviews">Reviews</a>
      <a href="#faq">FAQ</a>
    </nav>
    <div class="nav-right">
      <a href="#buy" class="nav-cta">Shop · {{ product.price | money }}</a>
      <button class="nav-menu-toggle" aria-label="Open menu" id="navToggle">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  <div class="nav-drawer" id="navDrawer" aria-hidden="true">
    <a href="#features">Features</a>
    <a href="#how">How it works</a>
    <a href="#reviews">Reviews</a>
    <a href="#faq">FAQ</a>
    <a href="#buy" class="drawer-cta">Shop now</a>
  </div>
</header>

<!-- ============== HERO / BUY ============== -->
<section id="top" class="hero">
  <div class="container hero-grid">

    <div class="gallery">
      <div class="gallery-main" id="galleryMain">
        <img src="{{ product.featured_image | image_url: width: 1600 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" id="galleryImage" loading="eager" fetchpriority="high">
        <video class="gallery-video" id="spinVideo" autoplay muted loop playsinline preload="metadata" style="display:none">
          <source src="{{ 'pawlens-360.mp4' | file_url }}" type="video/mp4">
        </video>
        <button class="gallery-spin-toggle" id="spinToggle" aria-pressed="false" title="360° spin">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4V1L7 5l5 4V6a6 6 0 1 1-6 6H4a8 8 0 1 0 8-8z" fill="currentColor"/></svg>
          <span>360°</span>
        </button>
      </div>
      <div class="gallery-thumbs" role="tablist" aria-label="Product photos">
        {%- for img in product.images -%}
        <button class="thumb{% if forloop.first %} active{% endif %}" data-src="{{ img | image_url: width: 1200 }}" aria-label="{{ img.alt | escape | default: product.title }}">
          <img src="{{ img | image_url: width: 240 }}" alt="" loading="lazy">
        </button>
        {%- endfor -%}
      </div>
    </div>

    <div class="buy" id="buy">
      <form action="{{ routes.cart_add_url }}" method="post" id="pawlens-add">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="pawlensVariantId">
        <input type="hidden" name="quantity" value="1">

        <p class="eyebrow"><span class="dot"></span>{{ section.settings.tagline }}</p>
        <h1 class="hero-title">{{ product.title }}</h1>
        <div class="stars" aria-label="4.9 out of 5 stars from 1,247 reviews">
          <span class="star-row" aria-hidden="true">★★★★★</span>
          <span class="star-text">4.9 · 1,247 happy pet parents</span>
        </div>
        <div class="hero-sub">{{ product.description }}</div>

        <div class="bundles" role="radiogroup" aria-label="Choose a bundle">
          {%- for variant in product.variants -%}
          {%- assign save = variant.compare_at_price | minus: variant.price -%}
          <label class="bundle{% if forloop.index == 2 %} bundle-featured{% endif %}">
            <input type="radio" name="bundle" value="{{ variant.id }}" data-price="{{ variant.price | divided_by: 100.0 }}" data-title="{{ variant.title | escape }}"{% if forloop.index == default_index %} checked{% endif %}>
            <span class="bundle-card">
              {%- if forloop.index == 2 and section.settings.badge_text != blank -%}
              <span class="badge-pop">{{ section.settings.badge_text }}</span>
              {%- endif -%}
              <span class="bundle-head">
                <span class="bundle-name">{{ variant.title }}</span>
                {%- if save > 0 -%}<span class="bundle-save">Save {{ save | money }}</span>{%- endif -%}
              </span>
              <span class="bundle-price">{% if variant.compare_at_price > variant.price %}<span class="strike">{{ variant.compare_at_price | money }}</span> {% endif %}<strong>{{ variant.price | money }}</strong></span>
              <span class="bundle-desc">{{ variant.metafields.custom.blurb | default: '' }}</span>
            </span>
          </label>
          {%- endfor -%}
        </div>

        <div class="addons">
          <p class="addons-label">Add to your order</p>
          <label class="addon">
            <input type="checkbox" data-price="15" data-title="Extra silicone collar">
            <span class="addon-row">
              <span class="addon-text"><strong>Extra silicone collar</strong><span> Backup or second pet</span></span>
              <span class="addon-price">+ $15</span>
            </span>
          </label>
          <label class="addon">
            <input type="checkbox" data-price="9" data-title="Travel pouch">
            <span class="addon-row">
              <span class="addon-text"><strong>Premium travel pouch</strong><span> Felt-lined, fits everything</span></span>
              <span class="addon-price">+ $9</span>
            </span>
          </label>
          <label class="addon">
            <input type="checkbox" data-price="12" data-title="2-year warranty">
            <span class="addon-row">
              <span class="addon-text"><strong>2-year extended warranty</strong><span> Drops, water, dog teeth</span></span>
              <span class="addon-price">+ $12</span>
            </span>
          </label>
        </div>

        <button class="cta-primary" id="ctaPrimary" type="submit">
          <span class="cta-label">Add to cart</span>
          <span class="cta-price" id="ctaPrice">{{ product.selected_or_first_available_variant.price | money }}</span>
        </button>
        <p class="finance">or 4 interest-free payments of <strong id="financePart">$19.75</strong> with <span class="afterpay">Afterpay</span> · <span class="klarna">Klarna</span></p>

        <ul class="hero-trust">
          <li>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h13l3 4h2v6h-2a2 2 0 1 1-4 0H10a2 2 0 1 1-4 0H3V7z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            Free US shipping
          </li>
          <li>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16v10H4z" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            30-day refunds
          </li>
          <li>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            1-year warranty
          </li>
        </ul>
      </form>
    </div>

  </div>
</section>

<!-- ============== TRUST STRIP ============== -->
<section class="trust-strip" aria-label="Why shop with us">
