{% schema %}
{
  "name": "Pawlens Product",
  "tag": "section",
  "class": "pawlens-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Eyebrow tagline",
      "default": "POV by pawlens"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Featured bundle badge",
      "info": "Shown on the 2nd bundle. Leave blank to hide.",
